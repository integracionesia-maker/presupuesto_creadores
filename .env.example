# ── Base de datos ──────────────────────────────────────────
# Ruta de la base de datos SQLite (relativa a backend/ o absoluta)
DATABASE_URL=sqlite:///./presupuesto.db

# ── Servidor ──────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ── CORS ──────────────────────────────────────────────────
# Orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Uploads ───────────────────────────────────────────────
# Directorio donde se guardan los archivos subidos
UPLOAD_DIR=./uploads

# ── Entorno ───────────────────────────────────────────────
# development | production — controla el flag Secure de las cookies de sesión
# y si /docs y /redoc quedan expuestos (solo en development).
ENV=development

# ── Autenticación ─────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Credenciales de la cuenta superadmin inicial (usadas solo por backend/seed_auth.py)
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_EMAIL=superadmin@grupo-ortiz.com
SUPERADMIN_PASSWORD=
